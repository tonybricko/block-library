---
import "@/styles/starwind.css";

interface Props {
  title: string;
  category: string;
  iframeSrc: string;
  source: string;
}

const { title, category, iframeSrc, source } = Astro.props;
const fullTitle = `${category} — ${title}`;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
  </head>
  <body class="flex h-screen flex-col overflow-hidden bg-white">

    <!-- Top bar -->
    <header class="flex flex-shrink-0 items-center justify-between border-b border-neutral-200 bg-white px-4 py-3">

      <!-- Left: back + title -->
      <div class="flex min-w-0 flex-1 items-center gap-3">
        <a
          href="/"
          class="flex flex-shrink-0 items-center justify-center rounded-md border border-neutral-200 p-2 text-neutral-600 transition-colors hover:bg-neutral-50"
          aria-label="Back to library"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m15 18-6-6 6-6"/>
          </svg>
        </a>
        <span class="truncate font-semibold text-neutral-900">{fullTitle}</span>
      </div>

      <!-- Center: device switcher -->
      <div class="flex items-center gap-1">
        <!-- Desktop -->
        <button data-device="desktop" class="flex items-center justify-center rounded-md border border-neutral-900 p-2 text-neutral-700 transition-colors hover:bg-neutral-50" aria-label="Desktop view">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="3" width="20" height="14" rx="2"/>
            <path d="M8 21h8M12 17v4"/>
          </svg>
        </button>
        <!-- Tablet -->
        <button data-device="tablet" class="flex items-center justify-center rounded-md border border-neutral-200 p-2 text-neutral-400 transition-colors hover:bg-neutral-50" aria-label="Tablet view">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="4" y="2" width="16" height="20" rx="2"/>
            <circle cx="12" cy="18.5" r="0.75" fill="currentColor" stroke="none"/>
          </svg>
        </button>
        <!-- Mobile -->
        <button data-device="mobile" class="flex items-center justify-center rounded-md border border-neutral-200 p-2 text-neutral-400 transition-colors hover:bg-neutral-50" aria-label="Mobile view">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="6" y="2" width="12" height="20" rx="2"/>
            <circle cx="12" cy="18.5" r="0.75" fill="currentColor" stroke="none"/>
          </svg>
        </button>
      </div>

      <!-- Right: source toggle -->
      <div class="flex flex-1 items-center justify-end">
        <button id="source-toggle" class="flex items-center gap-1.5 rounded-md border border-neutral-200 px-3 py-2 text-xs font-medium text-neutral-600 transition-colors hover:bg-neutral-50">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="16 18 22 12 16 6"/>
            <polyline points="8 6 2 12 8 18"/>
          </svg>
          Source
        </button>
      </div>
    </header>

    <!-- Body: preview + optional source drawer -->
    <div class="relative flex flex-1 overflow-hidden">

      <!-- Preview area -->
      <div id="preview-area" class="flex-1 overflow-y-auto bg-neutral-100 p-8">
        <div class="flex justify-center">
          <iframe
            id="preview-frame"
            src={iframeSrc}
            style="width: 100%; height: 600px; border: none; display: block;"
            title={fullTitle}
          ></iframe>
        </div>
      </div>

      <!-- Source drawer (hidden by default) -->
      <div id="source-drawer" class="hidden w-[480px] flex-shrink-0 flex-col border-l border-neutral-200 bg-white">
        <div class="flex flex-shrink-0 items-center justify-between border-b border-neutral-200 px-4 py-3">
          <span class="text-sm font-medium text-neutral-900">Component source</span>
          <div class="flex items-center gap-2">
            <button id="copy-source" class="rounded-md bg-neutral-950 px-3 py-1.5 text-xs font-semibold text-white transition-colors hover:bg-neutral-800">
              Copy
            </button>
            <button id="close-drawer" class="flex items-center justify-center rounded-md p-1 text-neutral-400 transition-colors hover:text-neutral-600" aria-label="Close source drawer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M18 6 6 18M6 6l12 12"/>
              </svg>
            </button>
          </div>
        </div>
        <div class="flex-1 overflow-y-auto p-4">
          <pre class="rounded-lg bg-neutral-50 p-4 text-xs leading-5 font-mono text-neutral-800 whitespace-pre overflow-x-auto"><code id="source-code"></code></pre>
        </div>
      </div>

    </div>

    <script is:inline define:vars={{ componentSource: source }}>
      var iframe = document.getElementById('preview-frame');
      var sourceDrawer = document.getElementById('source-drawer');
      var sourceCode = document.getElementById('source-code');
      var sourceToggle = document.getElementById('source-toggle');
      var closeDrawer = document.getElementById('close-drawer');
      var copyBtn = document.getElementById('copy-source');

      // Populate source safely via textContent (no HTML injection risk)
      sourceCode.textContent = componentSource;

      function syncHeight() {
        try {
          var h = iframe.contentDocument.documentElement.scrollHeight;
          if (h > 0) iframe.style.height = h + 'px';
        } catch(e) {}
      }

      function setDevice(device) {
        var widths = { desktop: '100%', tablet: '768px', mobile: '390px' };
        iframe.style.width = widths[device];
        document.querySelectorAll('[data-device]').forEach(function(btn) {
          var active = btn.dataset.device === device;
          btn.classList.toggle('border-neutral-900', active);
          btn.classList.toggle('text-neutral-700', active);
          btn.classList.toggle('border-neutral-200', !active);
          btn.classList.toggle('text-neutral-400', !active);
        });
        setTimeout(syncHeight, 150);
      }

      function toggleDrawer() {
        var isHidden = sourceDrawer.classList.contains('hidden');
        sourceDrawer.classList.toggle('hidden', !isHidden);
        sourceDrawer.classList.toggle('flex', isHidden);
      }

      iframe.addEventListener('load', syncHeight);

      document.querySelectorAll('[data-device]').forEach(function(btn) {
        btn.addEventListener('click', function() { setDevice(btn.dataset.device); });
      });

      sourceToggle.addEventListener('click', toggleDrawer);
      closeDrawer.addEventListener('click', toggleDrawer);

      document.addEventListener('keydown', function(e) {
        if (e.key === 'ArrowLeft' || e.key === 'ArrowRight') {
          try {
            iframe.contentDocument.dispatchEvent(new KeyboardEvent('keydown', { key: e.key, bubbles: true }));
          } catch(e) {}
        }
      });

      copyBtn.addEventListener('click', function() {
        navigator.clipboard.writeText(componentSource).then(function() {
          copyBtn.textContent = 'Copied!';
          setTimeout(function() { copyBtn.textContent = 'Copy'; }, 2000);
        }).catch(function() {
          copyBtn.textContent = 'Failed';
          setTimeout(function() { copyBtn.textContent = 'Copy'; }, 2000);
        });
      });
    </script>

  </body>
</html>
