---
import Layout from "@/layouts/Layout.astro";

const blocks: { category: string; slug: string; name: string }[] = [
  { category: "Hero", slug: "hero-card-fan", name: "Card Fan" },
  { category: "CTA", slug: "cta-email-register", name: "Email Register" },
  { category: "Testimonials", slug: "testimonials-with-rating", name: "With Rating" },
  { category: "Team", slug: "team-member-profile", name: "Member Profile" },
];

const grouped = blocks.reduce<Record<string, typeof blocks>>(
  (acc, block) => {
    (acc[block.category] ??= []).push(block);
    return acc;
  },
  {}
);
---

<Layout title="Block Library">
  <div class="min-h-screen bg-background">
    <header class="border-b border-border px-6 py-5">
      <h1 class="text-2xl font-semibold tracking-tight">Block Library</h1>
      <p class="text-sm text-muted-foreground mt-1">Reusable layout blocks for future projects.</p>
    </header>

    <main class="px-6 py-10 max-w-5xl mx-auto">
      {Object.keys(grouped).length === 0 ? (
        <div class="text-center py-24 text-muted-foreground">
          <p class="text-lg font-medium">No blocks yet.</p>
          <p class="text-sm mt-1">Add your first block to <code class="font-mono text-xs bg-muted px-1 py-0.5 rounded">src/components/blocks/</code></p>
        </div>
      ) : (
        Object.entries(grouped).map(([category, items]) => (
          <section class="mb-12">
            <h2 class="text-xs font-semibold uppercase tracking-widest text-muted-foreground mb-4">{category}</h2>
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {items.map(block => (
                <a
                  href={`/blocks/${block.slug}`}
                  class="group block rounded-lg border border-border bg-card p-5 hover:border-primary transition-colors"
                >
                  <span class="text-sm font-medium group-hover:text-primary transition-colors">{block.name}</span>
                </a>
              ))}
            </div>
          </section>
        ))
      )}
    </main>
  </div>
</Layout>
