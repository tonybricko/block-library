---
interface Props {
  tagline?: string;
  headline?: string;
  body?: string;
  primaryCTA?: { text: string; href: string };
  secondaryCTA?: { text: string; href: string };
  /**
   * Up to 3 image URLs. Slots: [left, center, right].
   * If omitted, placeholder cards are shown.
   */
  images?: string[];
}

const {
  tagline = "Tagline",
  headline = "Lorem ipsum dolor sit amet consectetur adipiscing",
  body = "Aliqua id fugiat nostrud irure ex duis ea quis id quis ad et. Sunt qui esse pariatur duis deserunt mollit dolore cillum minim tempor enim elit aute irure tempor cupidatat.",
  primaryCTA = { text: "Contact now", href: "#" },
  secondaryCTA = { text: "See more", href: "#" },
  images = [],
} = Astro.props;

const cardBg = [
  "background-color: #d4d4d4",
  "background-image: repeating-linear-gradient(-45deg, transparent 0px, transparent 4px, rgba(0,0,0,0.035) 4px, rgba(0,0,0,0.035) 5px)",
  "border: 1px solid rgba(255,255,255,0.55)",
].join("; ");
---

<section class="w-full overflow-hidden bg-white pb-16 sm:pb-20">
  <!-- Text content -->
  <div class="mx-auto max-w-2xl px-6 pt-12 text-center sm:pt-20">
    <p class="text-sm font-medium text-neutral-800">{tagline}</p>

    <h1
      class="mt-4 text-4xl font-bold leading-[1.1] tracking-tight text-neutral-950 sm:text-5xl lg:text-6xl"
    >
      {headline}
    </h1>

    <p class="mx-auto mt-6 max-w-lg text-base leading-relaxed text-neutral-500">
      {body}
    </p>

    <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
      <a
        href={primaryCTA.href}
        class="inline-flex w-full items-center justify-center rounded bg-neutral-950 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-neutral-800 sm:w-auto"
      >
        {primaryCTA.text}
      </a>
      <a
        href={secondaryCTA.href}
        class="inline-flex w-full items-center justify-center rounded border border-neutral-950 bg-transparent px-5 py-2.5 text-sm font-medium text-neutral-950 transition-colors hover:bg-neutral-100 sm:w-auto"
      >
        {secondaryCTA.text}
      </a>
    </div>
  </div>

  <!-- Card fan — CSS custom properties drive all sizing at each breakpoint -->
  <div
    class="relative mx-auto mt-10 sm:mt-16 [--fan-h:320px] sm:[--fan-h:430px] lg:[--fan-h:540px]"
    style="height: var(--fan-h);"
  >
    <!-- Left card -->
    <div
      class="absolute flex items-center justify-center overflow-hidden rounded-2xl
             [--sw:156px] [--sh:216px] [--spread:118px] sm:[--sw:232px] sm:[--sh:320px] sm:[--spread:188px] lg:[--sw:300px] lg:[--sh:412px] lg:[--spread:230px]"
      style={`${cardBg}; bottom: 0; left: 50%; width: var(--sw); height: var(--sh); transform: translateX(calc(-50% - var(--spread))) rotate(-12deg); z-index: 1;`}
    >
      {images[0]
        ? <img src={images[0]} alt="" class="h-full w-full object-cover" />
        : <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
      }
    </div>

    <!-- Center card — visible at all breakpoints -->
    <div
      class="absolute flex items-center justify-center overflow-hidden rounded-2xl
             [--cw:200px] [--ch:280px] sm:[--cw:268px] sm:[--ch:376px] lg:[--cw:344px] lg:[--ch:480px]"
      style={`${cardBg}; bottom: 0; left: 50%; width: var(--cw); height: var(--ch); transform: translateX(-50%); z-index: 10;`}
    >
      {images[1]
        ? <img src={images[1]} alt="" class="h-full w-full object-cover" />
        : <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
      }
    </div>

    <!-- Right card -->
    <div
      class="absolute flex items-center justify-center overflow-hidden rounded-2xl
             [--sw:156px] [--sh:216px] [--spread:118px] sm:[--sw:232px] sm:[--sh:320px] sm:[--spread:188px] lg:[--sw:300px] lg:[--sh:412px] lg:[--spread:230px]"
      style={`${cardBg}; bottom: 0; left: 50%; width: var(--sw); height: var(--sh); transform: translateX(calc(-50% + var(--spread))) rotate(12deg); z-index: 1;`}
    >
      {images[2]
        ? <img src={images[2]} alt="" class="h-full w-full object-cover" />
        : <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
            <circle cx="8.5" cy="8.5" r="1.5"/>
            <polyline points="21 15 16 10 5 21"/>
          </svg>
      }
    </div>
  </div>
</section>
