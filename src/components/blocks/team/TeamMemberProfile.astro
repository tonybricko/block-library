const placeholderBg = [
  "background-color: #d4d4d4",
  "background-image: repeating-linear-gradient(-45deg, transparent 0px, transparent 4px, rgba(0,0,0,0.035) 4px, rgba(0,0,0,0.035) 5px)",
  "border: 1px solid rgba(255,255,255,0.55)",
].join("; ");
---

<section class="bg-white px-4 py-8 sm:px-6 sm:py-10">
  <div class="mx-auto max-w-5xl">

    <!-- Profile header -->
    <div class="flex flex-col gap-8 sm:flex-row sm:items-start sm:gap-10 lg:gap-14">

      <!-- Photo -->
      <div class="w-full shrink-0 sm:w-52 md:w-64 lg:w-96">
        <div class="aspect-square overflow-hidden rounded-3xl" style={image ? "" : placeholderBg}>
          {image ? (
            <img src={image} alt={name} class="h-full w-full object-cover" />
          ) : (
            <div class="flex h-full items-center justify-center">
              <svg class="size-16 text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
            </div>
          )}
        </div>
      </div>

      <!-- Profile info -->
      <div class="min-w-0 flex-1">
        <p class="text-sm font-medium text-neutral-500">{tagline}</p>
        <h1 class="mt-1 text-4xl font-extrabold leading-[1.1] tracking-tight text-neutral-950 sm:text-5xl">
          {name}
        </h1>
        <p class="mt-3 text-xl text-neutral-700">{jobTitle}</p>
        <p class="mt-4 text-sm leading-relaxed text-neutral-500 sm:text-base">{bio}</p>

        <hr class="my-6 border-neutral-200" />

        <dl class="space-y-2.5">
          <div class="flex items-center gap-4">
            <dt class="min-w-[4.5rem] text-sm font-bold text-neutral-900">Email:</dt>
            <dd class="text-sm text-neutral-600">{email}</dd>
          </div>
          <div class="flex items-center gap-4">
            <dt class="min-w-[4.5rem] text-sm font-bold text-neutral-900">Phone:</dt>
            <dd class="text-sm text-neutral-600">{phone}</dd>
          </div>
        </dl>

        <hr class="my-6 border-neutral-200" />

        <div class="flex flex-wrap gap-5">
          {socials.map((social) => (
            <a
              href={social.href}
              aria-label={social.label}
              class="text-neutral-500 transition-colors hover:text-neutral-900"
            >
              <svg class="size-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={social.path} />
              </svg>
            </a>
          ))}
        </div>
      </div>

    </div>

    <hr class="my-8 border-neutral-200 sm:my-10" />

    <!-- About section -->
    <div class="max-w-2xl">
      <h2 class="text-2xl font-bold text-neutral-950 sm:text-3xl">{aboutHeading}</h2>
      <p class="mt-3 text-sm leading-relaxed text-neutral-600 sm:text-base">{aboutText}</p>

      <h3 class="mt-8 text-lg font-bold text-neutral-950 sm:text-xl">{highlightsHeading}</h3>
      <ul class="mt-3 list-outside list-disc space-y-1.5 pl-5">
        {highlights.map((item) => (
          <li class="text-sm leading-relaxed text-neutral-600 sm:text-base">{item}</li>
        ))}
      </ul>

      <h3 class="mt-8 text-lg font-bold text-neutral-950 sm:text-xl">{philosophyHeading}</h3>
      <div class="mt-3 space-y-4">
        {philosophyParagraphs.map((para) => (
          <p class="text-sm leading-relaxed text-neutral-600 sm:text-base">{para}</p>
        ))}
      </div>
    </div>

  </div>
</section>
