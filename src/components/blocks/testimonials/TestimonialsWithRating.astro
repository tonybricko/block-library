---
interface Testimonial {
  quote: string;
  name: string;
  title: string;
}

interface Props {
  tagline?: string;
  headline?: string;
  body?: string;
  rating?: number;
  ratingText?: string;
  avatars?: string[];
  testimonials?: Testimonial[];
}

const {
  tagline = "Tagline",
  headline = "Lorem ipsum dolor sit amet",
  body = "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt.",
  rating = 3.5,
  ratingText = "Over 1000+ satisfied users",
  avatars = [],
  testimonials = [
    {
      quote: "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.",
      name: "Adam Smith",
      title: "CEO, Company",
    },
    {
      quote: "Sed ut perspiciatis unde omnis iste natus error sit voluptatem accusantium doloremque laudantium, totam rem aperiam eaque ipsa quae ab illo inventore veritatis et quasi architecto beatae vitae.",
      name: "Jane Doe",
      title: "CTO, Startup",
    },
    {
      quote: "At vero eos et accusamus et iusto odio dignissimos ducimus qui blanditiis praesentium voluptatum deleniti atque corrupti quos dolores et quas molestias excepturi sint.",
      name: "Bob Johnson",
      title: "Founder, Agency",
    },
  ],
} = Astro.props;

const avatarSlots = Array.from({ length: 3 }, (_, i) => avatars[i] ?? null);

function starType(r: number, pos: number): "full" | "half" | "empty" {
  if (r >= pos) return "full";
  if (r >= pos - 0.5) return "half";
  return "empty";
}
const stars = [1, 2, 3, 4, 5].map((i) => starType(rating, i));

const starPoints = "12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2";
---

<section id="testimonials-block" class="bg-white px-4 py-6 sm:px-6 sm:py-8">
  <div class="rounded-2xl border border-neutral-200 lg:grid lg:grid-cols-2">

    <!-- Left: content -->
    <div class="flex flex-col justify-center p-8 sm:p-10 lg:p-12">
      <p class="text-sm font-semibold text-neutral-900">{tagline}</p>
      <h2 class="mt-3 text-3xl font-bold leading-[1.1] tracking-tight text-neutral-950 sm:text-4xl lg:text-5xl">
        {headline}
      </h2>
      <p class="mt-4 text-sm leading-relaxed text-neutral-500 sm:text-base">
        {body}
      </p>

      <!-- Avatars -->
      <div class="mt-6 flex items-center">
        {avatarSlots.map((src, i) => (
          <div
            class:list={[
              "flex items-center justify-center overflow-hidden rounded-full bg-neutral-200 ring-2 ring-white size-10 sm:size-11",
              i > 0 ? "-ml-2.5" : "",
            ]}
          >
            {src
              ? <img src={src} alt="" class="h-full w-full object-cover" />
              : <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="#a3a3a3" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
                  <circle cx="8.5" cy="8.5" r="1.5"/>
                  <polyline points="21 15 16 10 5 21"/>
                </svg>
            }
          </div>
        ))}
      </div>

      <!-- Star rating -->
      <div class="mt-4 flex items-center gap-0.5">
        {stars.map((type) => (
          type === "full" ? (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#0a0a0a" stroke="#0a0a0a" stroke-width="1.5" stroke-linejoin="round" aria-hidden="true">
              <polygon points={starPoints} />
            </svg>
          ) : type === "half" ? (
            <svg width="28" height="28" viewBox="0 0 24 24" aria-hidden="true">
              <defs>
                <linearGradient id="hsg">
                  <stop offset="50%" stop-color="#0a0a0a" />
                  <stop offset="50%" stop-color="#d4d4d4" />
                </linearGradient>
              </defs>
              <polygon fill="url(#hsg)" stroke="url(#hsg)" stroke-width="1.5" stroke-linejoin="round" points={starPoints} />
            </svg>
          ) : (
            <svg width="28" height="28" viewBox="0 0 24 24" fill="#d4d4d4" stroke="#d4d4d4" stroke-width="1.5" stroke-linejoin="round" aria-hidden="true">
              <polygon points={starPoints} />
            </svg>
          )
        ))}
      </div>
      <p class="mt-2 text-xs text-neutral-500">{ratingText}</p>
    </div>

    <!-- Right: testimonial carousel -->
    <div class="p-4 sm:p-5 lg:p-6">
      <div id="testimonial-card" class="flex h-full flex-col rounded-2xl bg-neutral-100">

        <!-- Slides -->
        <div class="flex flex-1 flex-col items-center justify-center p-8 text-center lg:p-10">
          <div class="grid w-full">
            {testimonials.map((t, i) => (
              <div
                data-slide={i}
                class:list={[
                  "[grid-area:1/1] transition-opacity duration-200",
                  i !== 0 ? "pointer-events-none select-none opacity-0" : "",
                ]}
              >
                <svg class="mx-auto w-10 h-8 fill-neutral-700" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 18 14">
                  <path d="M6 0H2a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4v1a3 3 0 0 1-3 3H2a1 1 0 0 0 0 2h1a5.006 5.006 0 0 0 5-5V2a2 2 0 0 0-2-2Zm10 0h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4v1a3 3 0 0 1-3 3h-1a1 1 0 0 0 0 2h1a5.006 5.006 0 0 0 5-5V2a2 2 0 0 0-2-2Z"/>
                </svg>
                <p class="mt-4 text-base leading-relaxed text-neutral-700 sm:text-lg">{t.quote}</p>
                <p class="mt-6 font-bold text-neutral-950">{t.name}</p>
                <p class="mt-1 text-sm text-neutral-500">{t.title}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Dots -->
        <div class="flex justify-center gap-2 pb-8">
          {testimonials.map((_, i) => (
            <button
              data-dot={i}
              class:list={[
                "size-3 rounded-full transition-colors",
                i === 0 ? "bg-neutral-950" : "bg-neutral-300",
              ]}
              aria-label={`Testimonial ${i + 1}`}
            />
          ))}
        </div>

      </div>
    </div>

  </div>
</section>

<script>
  const block = document.getElementById("testimonials-block");
  if (block) {
    const slides = block.querySelectorAll<HTMLElement>("[data-slide]");
    const dots = block.querySelectorAll<HTMLElement>("[data-dot]");

    let current = 0;
    const total = slides.length;

    function goTo(index: number) {
      current = (index + total) % total;
      slides.forEach((slide, i) => {
        slide.classList.toggle("opacity-0", i !== current);
        slide.classList.toggle("pointer-events-none", i !== current);
        slide.classList.toggle("select-none", i !== current);
      });
      dots.forEach((dot, i) => {
        dot.classList.toggle("bg-neutral-950", i === current);
        dot.classList.toggle("bg-neutral-300", i !== current);
      });
    }

    dots.forEach((dot, i) => dot.addEventListener("click", () => goTo(i)));

    document.addEventListener("keydown", (e) => {
      if (e.key === "ArrowRight") goTo(current + 1);
      if (e.key === "ArrowLeft") goTo(current - 1);
    });
  }
</script>
